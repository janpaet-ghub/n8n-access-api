<service>
  <id>n8nApiService</id>
  <name>n8n API Service</name>
  <description>Node.js n8n API for Microsoft Access DB (HMAC protected)</description>

  <!-- Path to Node.js -->
  <executable>C:\Programme\nodejs\node.exe</executable>

  <!-- Start script -->
  <arguments>server.js</arguments>

  <!-- Working directory -->
  <workingdirectory>C:\DATEN\Wichtige Daten\n8n\api\access\src</workingdirectory>
  
  <!-- Restart in case of error -->
  <restart delay="10 sec" />

  <!-- Logging -->
  <log mode="roll">
    <sizeThreshold>10485760</sizeThreshold> <!-- 10 MB -->
    <keepFiles>5</keepFiles>
  </log>

  <!-- Environment variables -->
  <env name="LINA_API_KEY" value="N8N_LINA_API_KEY" />
  <env name="LINA_HMAC_SECRET" value="N8N_LINA_HMAC_SECRET" />
   <env name="SIGNER_ALLOW_REMOTE" value="true" />
  <env name="ACCESS_DB_PATH" value="C:\DATEN\Wichtige Daten\n8n\api\access\backend_db\backend.accdb" />

  <env name="PORT" value="3000" />
  <env name="SIGNATURE_MAX_SKEW_SEC" value="300" />
  <env name="LOG_LEVEL" value="info" />
  <env name="LOG_FORMAT" value="json" />

</service>